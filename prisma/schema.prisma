generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Meal {
  id            String   @id @default(cuid())
  userId        String
  userEmail     String?
  imageUrl      String?
  mealType      String
  totalCalories Int
  totalProtein  Int
  totalCarbs    Int
  totalFats     Int
  healthTip     String?
  createdAt     DateTime @default(now())
  foods         Food[]

  @@map("meals")
}

model Food {
  id          String   @id @default(cuid())
  mealId      String
  name        String
  portionSize String
  calories    Int
  protein     Int
  carbs       Int
  fats        Int
  confidence  String
  createdAt   DateTime @default(now())
  meal        Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@map("foods")
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  userEmail      String   @unique
  name           String?
  weight         Float?
  height         Float?
  age            Int?
  gender         String?
  goal           String?
  activityLevel  String?
  targetCalories Int?
  targetProtein  Int?
  targetCarbs    Int?
  targetFats     Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("user_profiles")
}
